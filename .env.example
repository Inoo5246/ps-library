# ─── PS Library — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── API Keys (all optional, for metadata lookup) ───────────────────────────
# RAWG: https://rawg.io/apidocs (free, 20k requests/month)
RAWG_API_KEY=

# IGDB (via Twitch): https://dev.twitch.tv → Applications (free)
IGDB_CLIENT_ID=
IGDB_SECRET=

# MobyGames: https://www.mobygames.com/info/api (free, 360 requests/hour)
MOBY_API_KEY=

# ─── Paths (where your files are stored on the host) ────────────────────────
GAMES_PATH=./library/games
IMAGES_PATH=./library/images
DLC_PATH=./library/dlc
SAVES_PATH=./library/save
DOWNLOADS_PATH=./library/downloads

# ─── Upload limit (MB) ──────────────────────────────────────────────────────
MAX_UPLOAD_MB=50000
